# RepoDiscoverAI v3.0 - Environment Variables
# Copy this file to .env and fill in your values

# GitHub API (Required for trend monitoring)
GITHUB_TOKEN=your_github_token_here

# ElevenLabs API (Required for podcast generation)
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_multilingual_v2

# Shotstack API (Required for YouTube video generation)
SHOTSTACK_API_KEY=your_shotstack_api_key
SHOTSTACK_BASE_URL=https://api.shotstack.io/v1

# Twitter/X API (Required for social media posting)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret

# Site Configuration
SITE_URL=https://repodiscoverai.com
OUTPUT_DIR=./output

# Optional: Redis (for caching)
REDIS_URL=redis://localhost:6379/0

# Optional: Monitoring
PROMETHEUS_PORT=9090
LOG_LEVEL=INFO
