# ============================================
# RepoDiscoverAI - Environment Configuration
# ============================================
# Copy this file to .env and update values
# cp .env.example .env

# ============================================
# Application Settings
# ============================================
SECRET_KEY=your-super-secret-key-change-in-production
ENVIRONMENT=production
LOG_LEVEL=INFO
DEBUG=false

# Application URL
APP_URL=https://your-domain.com
FRONTEND_URL=https://your-domain.com

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=repodiscover
DB_USER=repodiscover
DB_PASSWORD=changeme-change-in-production

# Database URL (auto-generated)
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Redis URL (auto-generated)
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# ============================================
# GitHub API Configuration
# ============================================
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_API_URL=https://api.github.com

# Rate limiting (requests per hour)
GITHUB_RATE_LIMIT=5000

# ============================================
# Email Configuration (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@repodiscoverai.com
SMTP_TLS=true

# ============================================
# Monitoring & Observability
# ============================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin-change-in-production

PROMETHEUS_RETENTION_DAYS=15

# ============================================
# Security Settings
# ============================================
# Rate limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=100

# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Session settings
SESSION_EXPIRE_HOURS=24
MAX_LOGIN_ATTEMPTS=5

# ============================================
# Backup Settings
# ============================================
BACKUP_DIR=/backups
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *

# ============================================
# Docker & Deployment
# ============================================
REPO_OWNER=wei
DEPLOY_HOST=your-server-ip
DEPLOY_USER=deploy
DEPLOY_URL=https://your-domain.com

# ============================================
# Feature Flags
# ============================================
ENABLE_CACHE=true
ENABLE_RATE_LIMIT=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_WEBHOOKS=true
ENABLE_ANALYTICS=true

# ============================================
# Performance Tuning
# ============================================
# Connection pool settings
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20

# Cache TTL (seconds)
CACHE_TTL_DEFAULT=300
CACHE_TTL_TRENDING=60
CACHE_TTL_SEARCH=120

# Worker settings
WORKER_COUNT=4
WORKER_TIMEOUT=30
