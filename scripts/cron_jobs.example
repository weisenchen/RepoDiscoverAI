# GitHub Trending Scraper - Cron Job Configuration
# 
# Install with: crontab /path/to/cron_jobs.example
# Or manually: crontab -e and paste these lines
#
# Note: Adjust paths and times to your timezone

# Environment setup
SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin
MAILTO=""

# ============================================
# DAILY SCRAPES (6:00 AM EST = 10:00 UTC)
# ============================================

# Daily scrape - all languages, today's trending
0 10 * * * cd /home/wei/.openclaw/workspace/RepoDiscoverAI && /usr/bin/python3 scripts/github_trending_scraper.py --period today >> logs/trending_daily.log 2>&1

# Daily scrape - Python repos
15 10 * * * cd /home/wei/.openclaw/workspace/RepoDiscoverAI && /usr/bin/python3 scripts/github_trending_scraper.py --language python --period today >> logs/trending_python.log 2>&1

# Daily scrape - JavaScript repos
30 10 * * * cd /home/wei/.openclaw/workspace/RepoDiscoverAI && /usr/bin/python3 scripts/github_trending_scraper.py --language javascript --period today >> logs/trending_js.log 2>&1

# Daily scrape - Rust repos
45 10 * * * cd /home/wei/.openclaw/workspace/RepoDiscoverAI && /usr/bin/python3 scripts/github_trending_scraper.py --language rust --period today >> logs/trending_rust.log 2>&1

# ============================================
# WEEKLY SCRAPES (Monday 9:00 AM EST = 13:00 UTC)
# ============================================

# Weekly summary - all languages
0 13 * * 1 cd /home/wei/.openclaw/workspace/RepoDiscoverAI && /usr/bin/python3 scripts/github_trending_scraper.py --period week >> logs/trending_weekly.log 2>&1

# Weekly summary - Python
15 13 * * 1 cd /home/wei/.openclaw/workspace/RepoDiscoverAI && /usr/bin/python3 scripts/github_trending_scraper.py --language python --period week >> logs/trending_python_weekly.log 2>&1

# ============================================
# MONTHLY SCRAPES (1st of month, 10:00 AM EST = 14:00 UTC)
# ============================================

# Monthly summary - all languages
0 14 1 * * cd /home/wei/.openclaw/workspace/RepoDiscoverAI && /usr/bin/python3 scripts/github_trending_scraper.py --period month >> logs/trending_monthly.log 2>&1

# ============================================
# MAINTENANCE TASKS
# ============================================

# Clean old log files (keep last 30 days) - Sundays at 3 AM
0 7 * * 0 find /home/wei/.openclaw/workspace/RepoDiscoverAI/logs -name "*.log" -mtime +30 -delete

# Clean old data files (keep last 90 days) - 1st of month at 4 AM
0 8 1 * * find /home/wei/.openclaw/workspace/RepoDiscoverAI/data -name "*.json" -mtime +90 -delete
